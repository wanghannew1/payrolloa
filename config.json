{
  "excel": {
    "title_row": 1,
    "unit_name_row": 0,
    "header_start_row": 2,
    "header_row_count": 3,
    "summary_row_marker": "合计",
    "unit_name_patterns": [
      "(?:单位名称[：:]|[名称][：:]\\s*)(.+?)(?:\\s|$)"
    ],
    "title_unit_suffixes": [
      "有限公司", "股份公司", "分公司", "公司", "集团",
      "医院", "卫生院", "诊所",
      "研究院", "研究所", "学院", "大学", "学校",
      "中心", "管委会", "事业部", "处", "局"
    ],
    "title_unit_allowed_chars": "[一-龥A-Za-z0-9（）()·\\-—]",
    "title_unit_patterns": [],
    "columns": {
      "transfer_total": {
        "keywords": ["转账合计", "转款合计"],
        "label": "转账合计（元）"
      },
      "deduction_total": {
        "keywords": ["扣款合计"],
        "label": "扣款合计（五险一金、单位代理费）"
      },
      "net_total": {
        "keywords": ["实发合计", "实发工资"],
        "label": "实发工资（元）"
      },
      "personal_tax": {
        "keywords": ["个人所得税", "个税"],
        "label": "个人所得税"
      },
      "adjustment": {
        "keywords": ["个人其他调整"],
        "label": "个人其他调整"
      },
      "tax_and_fee": {
        "keywords": ["税费"],
        "label": "税费"
      }
    },
    "extra_summary_rows": {
      "overpayment_offset": {
        "keywords": ["溢缴款抵扣"],
        "label": "溢缴款抵扣"
      },
      "party_a_transfer": {
        "keywords": ["甲方转款"],
        "label": "甲方转款"
      }
    }
  },
  "validation": {
    "enabled": true,
    "strict": true,
    "tolerance": 0.00,
    "write_back_sheet": true,
    "write_back_sheet_name": "验证结果",
    "column_sum_checks": [
      {"column": "deduction_total"},
      {"column": "personal_tax"},
      {"column": "net_total"},
      {"column": "adjustment"}
    ],
    "row_formulas": [
      {
        "name": "转账合计 = 税费 + 扣款合计 + 个人所得税 + 个人其他调整 + 实发合计",
        "lhs": "transfer_total",
        "rhs_plus": ["tax_and_fee", "deduction_total", "personal_tax", "adjustment", "net_total"],
        "rhs_minus": []
      }
    ],
    "extra_summary_checks": [
      {
        "name": "转款合计 = 溢缴款抵扣 + 甲方转款",
        "column": "transfer_total",
        "lhs_row_key": "summary",
        "rhs_plus_row_keys": ["overpayment_offset", "party_a_transfer"],
        "rhs_minus_row_keys": []
      }
    ]
  },
  "table_field": {
    "columns": [
      {"key": "report_name", "label": "报表名称"},
      {"key": "party_a_transfer", "label": "甲方转款（元）"},
      {"key": "overpayment_offset", "label": "溢缴款抵扣（元）"},
      {"key": "transfer_total", "label": "转账合计（含抵扣）"},
      {"key": "deduction_total", "label": "扣款合计（五险一金、单位代理费）"},
      {"key": "personal_tax", "label": "个人所得税合计（元）"},
      {"key": "adjustment", "label": "其他调整合计（元）"},
      {"key": "net_total", "label": "实发工资（元）"}
    ]
  },
  "ui": {
    "template_name": "212室彩虹公司项目工资发放审批",
    "description": "上传212室彩虹公司项目手工编写的工资发放表，对应的OA审批名称：工资发放审批（手工做表），上传页面会自动校验转账合计、扣款合计、个税、实发工资等数值"
  }
}
